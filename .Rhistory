for (pkg in pkgs) {
  cat(pkg, ":", ifelse(requireNamespace(pkg, quietly=TRUE), "OK", "MISSING"), "\n")
}
# Bioconductor mirror 변경
options(BioC_mirror = "https://bioc.ism.ac.jp")
# sva 재시도
BiocManager::install("sva", ask = FALSE)
# sva GitHub 버전
devtools::install_github("jtleek/sva-devel")
# MMUPHin GitHub 버전  
devtools::install_github("biobakery/MMUPHin")
# sva 의존성 (Bioconductor 패키지들)
bioc_pkgs <- c("BiocParallel", "limma", "edgeR", "genefilter", "matrixStats")
BiocManager::install(bioc_pkgs, ask = FALSE)
# 확인
for (pkg in bioc_pkgs) {
  cat(pkg, ":", ifelse(requireNamespace(pkg, quietly=TRUE), "OK", "MISSING"), "\n")
}
BiocManager::install(matrixStats, ask = FALSE, force=TRUE)
matrixStats
BiocManager::install("matrixStats", ask = FALSE, force=TRUE)
# CRAN archive에서 직접 설치
pkgs_urls <- c(
  "https://bioconductor.org/packages/3.18/bioc/src/contrib/BiocParallel_1.36.0.tar.gz",
  "https://bioconductor.org/packages/3.18/bioc/src/contrib/limma_3.58.1.tar.gz",
  "https://bioconductor.org/packages/3.18/bioc/src/contrib/edgeR_4.0.16.tar.gz",
  "https://bioconductor.org/packages/3.18/bioc/src/contrib/genefilter_1.84.0.tar.gz"
)
for (url in pkgs_urls) {
  install.packages(url, repos = NULL, type = "source")
}
q()
