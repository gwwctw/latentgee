devtools::install_github("theislab/kBET")
requireNamespace("kBET", quietly = TRUE)
quit()
install.packages("fastDummies", repos = "https://cran.r-project.org")
q()
install.packages("data.table", repos = "https://cran.r-project.org")
install.packages("fastDummies", repos = "https://cran.r-project.org")
requireNamespace("fastDummies", quietly = TRUE)
devtools::install_github("wdl2459/ConQuR")
