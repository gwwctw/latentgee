  type = "source"
)
# 설치된 패키지 확인
installed.packages()[c("FNN", "RColorBrewer", "ggplot2", "cluster", "MASS", "vegan"), "Version"]
pkgs <- c("FNN", "RColorBrewer", "ggplot2", "cluster", "MASS", "vegan")
for (pkg in pkgs) {
  installed <- requireNamespace(pkg, quietly = TRUE)
  cat(pkg, ":", ifelse(installed, "OK", "MISSING"), "\n")
}
install.packages(
  "https://cran.r-project.org/src/contrib/Archive/permute/permute_0.9-7.tar.gz",
  repos = NULL,
  type = "source"
)
