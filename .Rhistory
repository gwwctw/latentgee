# 3. sva를 CRAN archive에서 직접 설치 (Bioconductor 우회)
install.packages(
  "https://cran.r-project.org/src/contrib/Archive/sva/sva_3.50.0.tar.gz",
  repos = NULL,
  type = "source"
)
# 4. MMUPHin도 CRAN archive에서 시도
install.packages(
  "https://cran.r-project.org/src/contrib/Archive/MMUPHin/MMUPHin_1.8.0.tar.gz",
  repos = NULL,
  type = "source"
)
