# 인터넷 연결 확인
tryCatch(
  readLines("https://cran.r-project.org"),
  error = function(e) print(e)
)
# 1. kBET 의존성 먼저
install.packages(c("FNN", "RColorBrewer", "ggplot2", "cluster", "MASS", "vegan"))
